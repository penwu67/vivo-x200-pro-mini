tải ADB, bật development -> usb debugging
mở CMD chạy lệnh sau:

adb shell
LIST="com.vivo.assistant com.vivo.favorite com.vivo.nightpearl com.vivo.doubleinstance com.vivo.audiofx com.vivo.numbermark com.android.vendors.bridge.softsim com.mediatek.gbaservice com.vivo.cota com.debug.loggerui com.vivo.devicereg com.vivo.floatingball com.vivo.findphone com.vivo.gamewatch com.vivo.globalanimation com.vivo.globalsearch com.vivo.setupwizard com.vivo.upslide com.vivo.iotserver com.vivo.magazine com.vivo.minscreen com.vivo.musicwidgetmix com.vivo.pushservice com.vivo.SmartKey com.vivo.quickpay com.vivo.upnpserver com.vivo.secime.service com.vivo.safecenter com.vivo.abe com.bbk.SuperPowerSave com.vivo.sps com.android.BBKCrontab com.vivo.vibrator4d com.vivo.videoeditor com.android.vivo.tws.vivotws com.bbk.cloud com.vivo.daemonService com.vivo.vms com.vivo.weather.provider com.vivo.voicewakeup"

for pkg in $LIST; do
  cmd appops set $pkg RUN_IN_BACKGROUND ignore
  cmd appops set $pkg RUN_ANY_IN_BACKGROUND ignore
  cmd appops set $pkg START_FOREGROUND ignore
done
exit


